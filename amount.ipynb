   "source": [
    "\n",
    "bill = float(input(\"Enter total bill amount\"))\n",
    "tip_percent = float(input(\"Enter tip percentage\"))\n",
    "\n",
    "tip_rate = tip_percent/100\n",
    "tip = bill* tip_rate\n",
    "total = bill + tip\n",
    "\n",
    "tip = round(tip,2)\n",
    "total = round(total,2)\n",
    "\n",
    "print(\"Tip amount:\",tip)\n",
    "print(\"Total amount:\",total)\n",
    "\n",
    "\n"
   ]
  }
